{
  "openapi": "3.0.0",
  "info": {
    "title": "ollama-models Workers API",
    "version": "0.1.0",
    "description": "Scrapes ollama.com to expose model search and tag listing as a JSON HTTP API. Hosted on Cloudflare Workers."
  },
  "servers": [
    {
      "url": "https://ollama-models-api.devcomfort.workers.dev"
    }
  ],
  "components": {
    "schemas": {},
    "parameters": {}
  },
  "paths": {
    "/search": {
      "get": {
        "tags": [
          "Search"
        ],
        "summary": "Search Ollama models by keyword",
        "description": "Returns all model pages found on the requested Ollama search results page. `page` defaults to `1`; invalid values are clamped to `1`. `q` defaults to an empty string (all models). Responds with `500` when the scraper throws (e.g. Ollama down, HTML structure changed).",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "q",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "page",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Model pages found on the requested search page.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "pages": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "http_url": {
                            "type": "string"
                          },
                          "model_id": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "http_url",
                          "model_id"
                        ]
                      }
                    },
                    "page_range": {
                      "anyOf": [
                        {
                          "type": "number"
                        },
                        {
                          "type": "object",
                          "properties": {
                            "from": {
                              "type": "number"
                            },
                            "to": {
                              "type": "number"
                            }
                          },
                          "required": [
                            "from",
                            "to"
                          ]
                        }
                      ]
                    },
                    "keyword": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "pages",
                    "page_range",
                    "keyword"
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Scraper error — Ollama may be down or its HTML structure changed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/model": {
      "get": {
        "tags": [
          "Model"
        ],
        "summary": "Retrieve all available tags for a model",
        "description": "Returns the model URL, model ID, full tag list, and `default_tag` (`null` when no `latest` tag exists). Accepted `name` formats: `library/qwen3`, `RogerBen/custom-model`, or a full `https://ollama.com/…` URL.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "name",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Model tags and metadata.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "page_url": {
                      "type": "string"
                    },
                    "id": {
                      "type": "string"
                    },
                    "tags": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "default_tag": {
                      "type": "string",
                      "nullable": true
                    }
                  },
                  "required": [
                    "page_url",
                    "id",
                    "tags",
                    "default_tag"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid `name` parameter.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Scraper error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Run a live health check against both scrapers",
        "description": "Probes both scrapers with stable inputs and returns a structured result. Responds with `200` when all checks pass, `503` when any fail. Never throws.",
        "responses": {
          "200": {
            "description": "All scraper checks passed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "timestamp": {
                      "type": "string"
                    },
                    "checks": {
                      "type": "object",
                      "properties": {
                        "search": {
                          "type": "object",
                          "properties": {
                            "ok": {
                              "type": "boolean"
                            },
                            "count": {
                              "type": "integer"
                            },
                            "error": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "ok"
                          ]
                        },
                        "model": {
                          "type": "object",
                          "properties": {
                            "ok": {
                              "type": "boolean"
                            },
                            "count": {
                              "type": "integer"
                            },
                            "error": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "ok"
                          ]
                        }
                      },
                      "required": [
                        "search",
                        "model"
                      ]
                    }
                  },
                  "required": [
                    "ok",
                    "timestamp",
                    "checks"
                  ]
                }
              }
            }
          },
          "503": {
            "description": "One or more scraper checks failed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "timestamp": {
                      "type": "string"
                    },
                    "checks": {
                      "type": "object",
                      "properties": {
                        "search": {
                          "type": "object",
                          "properties": {
                            "ok": {
                              "type": "boolean"
                            },
                            "count": {
                              "type": "integer"
                            },
                            "error": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "ok"
                          ]
                        },
                        "model": {
                          "type": "object",
                          "properties": {
                            "ok": {
                              "type": "boolean"
                            },
                            "count": {
                              "type": "integer"
                            },
                            "error": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "ok"
                          ]
                        }
                      },
                      "required": [
                        "search",
                        "model"
                      ]
                    }
                  },
                  "required": [
                    "ok",
                    "timestamp",
                    "checks"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
