---
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Try Now — ollama-models</title>
    <style>
      :root {
        --bg: #0d1117; --fg: #e6edf3; --card: #161b22;
        --border: #30363d; --accent: #58a6ff; --green: #3fb950; --red: #f85149;
        --gray-2: #8b949e; --gray-5: #30363d; --gray-6: #161b22;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); color: var(--fg); padding: 2rem; max-width: 64rem; margin: 0 auto; position: relative; }

      /* Language Select */
      .lang-select { position: absolute; top: 1.5rem; right: 2rem; z-index: 10; }
      .lang-select-trigger {
        display: flex; align-items: center; gap: 0.4rem;
        padding: 0.35rem 0.65rem; background: var(--card); border: 1px solid var(--border);
        border-radius: 0.375rem; cursor: pointer; font-size: 0.8rem; color: var(--fg);
        user-select: none; transition: border-color 0.15s;
      }
      .lang-select-trigger:hover { border-color: var(--accent); }
      .lang-select-trigger .flag { font-size: 1rem; }
      .lang-select-trigger .arrow { font-size: 0.6rem; color: var(--gray-2); margin-left: 0.2rem; transition: transform 0.2s; }
      .lang-select.open .arrow { transform: rotate(180deg); }
      .lang-select.open .lang-select-trigger { border-color: var(--accent); }
      .lang-options {
        position: absolute; top: calc(100% + 0.25rem); right: 0;
        background: var(--card); border: 1px solid var(--border); border-radius: 0.375rem;
        overflow: hidden; min-width: 100%; opacity: 0; transform: translateY(-0.25rem);
        pointer-events: none; transition: opacity 0.15s, transform 0.15s;
      }
      .lang-select.open .lang-options { opacity: 1; transform: translateY(0); pointer-events: auto; }
      .lang-option {
        display: flex; align-items: center; gap: 0.4rem;
        padding: 0.4rem 0.65rem; cursor: pointer; font-size: 0.8rem; color: var(--fg);
        transition: background 0.1s;
      }
      .lang-option:hover { background: var(--accent); color: #fff; }
      .lang-option.active { color: var(--accent); }

      /* Layout */
      h1 { font-size: 2rem; margin-bottom: 0.25rem; }
      p.sub { color: var(--gray-2); margin-bottom: 2rem; }
      section { background: var(--card); border: 1px solid var(--border); border-radius: 0.5rem; padding: 1.5rem; margin-bottom: 1.5rem; }
      h2 { font-size: 1.25rem; margin-bottom: 1rem; }

      /* Form */
      form { display: flex; gap: 0.5rem; margin-bottom: 1rem; }
      input[type="text"] {
        flex: 1; padding: 0.6rem 0.75rem; border: 1px solid var(--border);
        border-radius: 0.375rem; background: var(--bg); color: var(--fg); font-size: 0.9rem;
        transition: border-color 0.15s;
      }
      input:focus { outline: none; border-color: var(--accent); }
      input::placeholder { color: #484f58; }
      button[type="submit"], #health-btn {
        padding: 0.6rem 1.25rem; background: var(--accent); color: #fff;
        border: none; border-radius: 0.375rem; cursor: pointer; font-weight: 600; font-size: 0.9rem;
        transition: opacity 0.15s, transform 0.1s;
      }
      button:hover { opacity: 0.9; }
      button:active { transform: scale(0.97); }

      /* Status & Results */
      .status { font-size: 0.8rem; margin-bottom: 0.5rem; min-height: 1.2rem; transition: color 0.2s; }
      .status.ok { color: var(--green); }
      .status.err { color: var(--red); }
      .status.loading { color: var(--gray-2); }
      pre {
        background: var(--bg); border: 1px solid var(--border); border-radius: 0.375rem;
        padding: 1rem; overflow: auto; max-height: 20rem; font-size: 0.8rem; display: none;
        line-height: 1.5;
      }
      pre.visible { display: block; }

      /* Back link */
      a.back { color: var(--accent); text-decoration: none; font-size: 0.875rem; display: inline-block; margin-bottom: 1.5rem; }
      a.back:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    <!-- Language Select -->
    <div class="lang-select" id="lang-select">
      <div class="lang-select-trigger" id="lang-trigger">
        <span class="flag" id="lang-flag">🇺🇸</span>
        <span id="lang-label">English</span>
        <span class="arrow">▼</span>
      </div>
      <div class="lang-options" id="lang-options">
        <div class="lang-option" data-lang="en">
          <span class="flag">🇺🇸</span> English
        </div>
        <div class="lang-option" data-lang="ko">
          <span class="flag">🇰🇷</span> 한국어
        </div>
      </div>
    </div>

    <a class="back" id="back-link" href="/en/">← Back to docs</a>
    <h1 id="title"></h1>
    <p class="sub" id="subtitle"></p>

    <section>
      <h2 id="search-title"></h2>
      <form id="search-form">
        <input type="text" id="search-q" />
        <button type="submit" id="search-btn"></button>
      </form>
      <div class="status" id="search-status"></div>
      <pre id="search-result"><code></code></pre>
    </section>

    <section>
      <h2 id="model-title"></h2>
      <form id="model-form">
        <input type="text" id="model-name" />
        <button type="submit" id="model-btn"></button>
      </form>
      <div class="status" id="model-status"></div>
      <pre id="model-result"><code></code></pre>
    </section>

    <section>
      <h2 id="health-title"></h2>
      <button id="health-btn"></button>
      <div class="status" id="health-status"></div>
      <pre id="health-result"><code></code></pre>
    </section>

    <script is:inline>
      var API = '/api';
      var i18n = {
        en: {
          flag: '🇺🇸', label: 'English',
          back: '← Back to docs',
          title: 'Try ollama-models API',
          subtitle: 'Search and explore Ollama models interactively.',
          searchTitle: '🔍 Search Models',
          searchPlaceholder: 'e.g. qwen3, llama, code',
          searchBtn: 'Search',
          modelTitle: '📦 Get Model Tags',
          modelPlaceholder: 'e.g. library/qwen3',
          modelBtn: 'Get Tags',
          healthTitle: '💚 Health Check',
          healthBtn: 'Check Health',
          loading: 'Loading...',
          success: 'Success',
          error: 'Error',
          networkError: 'Network error',
        },
        ko: {
          flag: '🇰🇷', label: '한국어',
          back: '← 문서로 돌아가기',
          title: 'ollama-models API 체험하기',
          subtitle: 'Ollama 모델을 대화형으로 검색하고 탐색하세요.',
          searchTitle: '🔍 모델 검색',
          searchPlaceholder: '예: qwen3, llama, code',
          searchBtn: '검색',
          modelTitle: '📦 모델 태그 조회',
          modelPlaceholder: '예: library/qwen3',
          modelBtn: '태그 조회',
          healthTitle: '💚 헬스 체크',
          healthBtn: '상태 확인',
          loading: '로딩 중...',
          success: '成功',
          error: '오류',
          networkError: '네트워크 오류',
        }
      };

      var currentLang = localStorage.getItem('lang') || 'en';

      function setLang(lang) {
        currentLang = lang;
        localStorage.setItem('lang', lang);
        applyLang(lang);
        updateSelectUI(lang);
        closeSelect();
      }

      function applyLang(lang) {
        var t = i18n[lang];
        document.getElementById('back-link').textContent = t.back;
        document.getElementById('back-link').href = '/' + lang + '/';
        document.getElementById('title').textContent = t.title;
        document.getElementById('subtitle').textContent = t.subtitle;
        document.getElementById('search-title').textContent = t.searchTitle;
        document.getElementById('search-q').placeholder = t.searchPlaceholder;
        document.getElementById('search-btn').textContent = t.searchBtn;
        document.getElementById('model-title').textContent = t.modelTitle;
        document.getElementById('model-name').placeholder = t.modelPlaceholder;
        document.getElementById('model-btn').textContent = t.modelBtn;
        document.getElementById('health-title').textContent = t.healthTitle;
        document.getElementById('health-btn').textContent = t.healthBtn;
        document.documentElement.lang = lang;
      }

      function updateSelectUI(lang) {
        var t = i18n[lang];
        document.getElementById('lang-flag').textContent = t.flag;
        document.getElementById('lang-label').textContent = t.label;
        var opts = document.querySelectorAll('.lang-option');
        for (var i = 0; i < opts.length; i++) {
          opts[i].classList.toggle('active', opts[i].getAttribute('data-lang') === lang);
        }
      }

      // Select dropdown toggle
      var selectEl = document.getElementById('lang-select');
      var triggerEl = document.getElementById('lang-trigger');

      function closeSelect() { selectEl.classList.remove('open'); }

      triggerEl.addEventListener('click', function(e) {
        e.stopPropagation();
        selectEl.classList.toggle('open');
      });

      document.addEventListener('click', closeSelect);

      var options = document.querySelectorAll('.lang-option');
      for (var i = 0; i < options.length; i++) {
        options[i].addEventListener('click', function() {
          setLang(this.getAttribute('data-lang'));
        });
      }

      // Init
      applyLang(currentLang);
      updateSelectUI(currentLang);

      function call(path, statusEl, resultEl) {
        var t = i18n[currentLang];
        statusEl.className = 'status loading';
        statusEl.textContent = t.loading;
        resultEl.classList.remove('visible');
        fetch(API + path).then(function(res) {
          return res.json().then(function(data) {
            statusEl.className = 'status ' + (res.ok ? 'ok' : 'err');
            statusEl.textContent = res.ok ? t.success + ' (HTTP ' + res.status + ')' : t.error + ' (HTTP ' + res.status + ')';
            resultEl.querySelector('code').textContent = JSON.stringify(data, null, 2);
            resultEl.classList.add('visible');
          });
        }).catch(function(e) {
          statusEl.className = 'status err';
          statusEl.textContent = t.networkError + ': ' + e.message;
        });
      }

      document.getElementById('search-form').addEventListener('submit', function(e) {
        e.preventDefault();
        var q = document.getElementById('search-q').value.trim();
        if (q) call('/search?q=' + encodeURIComponent(q), document.getElementById('search-status'), document.getElementById('search-result'));
      });

      document.getElementById('model-form').addEventListener('submit', function(e) {
        e.preventDefault();
        var n = document.getElementById('model-name').value.trim();
        if (n) call('/model?name=' + encodeURIComponent(n), document.getElementById('model-status'), document.getElementById('model-result'));
      });

      document.getElementById('health-btn').addEventListener('click', function() {
        call('/health', document.getElementById('health-status'), document.getElementById('health-result'));
      });
    </script>
  </body>
</html>
