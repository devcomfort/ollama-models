{
    "name": "ollama-models",
    "private": true,
    "version": "0.0.0",
    "scripts": {
        "dev": "pnpm --filter ollama-models-api dev",
        "deploy": "pnpm --filter ollama-models-api deploy",
        "build": "pnpm --filter @devcomfort/ollama-models build",
        "gen-openapi": "pnpm --filter ollama-models-api gen-openapi",
        "type-check": "pnpm -r type-check",
        "test": "pnpm -r run test && pnpm test:py && pnpm test:lint-readme",
        "test:api": "pnpm --filter ollama-models-api test",
        "test:ts": "pnpm --filter @devcomfort/ollama-models test",
        "test:py": "cd packages/py-client && SKIP_INTEGRATION=1 rye run pytest",
        "test:lint-readme": "! grep -rE 'default_model_id|model_list|ModelWeight' README.md packages/*/README.md && echo 'All README schema names are current.'",
        "py:sync": "cd packages/py-client && rye sync",
        "py:build": "cd packages/py-client && rye run python -m build",
        "py:publish": "cd packages/py-client && rye run twine upload dist/*",
        "ts:publish": "pnpm --filter @devcomfort/ollama-models publish --access public"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "sharp",
            "workerd"
        ]
    },
    "packageManager": "pnpm@10.22.0+sha512.bf049efe995b28f527fd2b41ae0474ce29186f7edcb3bf545087bd61fbbebb2bf75362d1307fda09c2d288e1e499787ac12d4fcb617a974718a6051f2eee741c",
    "devDependencies": {
        "tsx": "^4.21.0"
    }
}
