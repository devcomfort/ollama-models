{
    "name": "ollama-models",
    "private": true,
    "version": "0.0.0",
    "scripts": {
        "dev": "nx dev api",
        "deploy": "nx deploy api",
        "build": "nx run-many -t build",
        "gen-openapi": "nx run api:gen-openapi",
        "type-check": "nx run-many -t type-check",
        "test": "pnpm test:api && pnpm test:ts && pnpm test:py && pnpm test:e2e && pnpm test:lint-readme",
        "test:api": "nx test api",
        "test:api:cov": "cd api && pnpm exec vitest run --coverage",
        "test:ts": "nx test ts-client",
        "test:ts:cov": "cd packages/ts-client && pnpm exec vitest run --coverage",
        "test:py": "cd packages/py-client && uv run pytest --cov=src/ollama_models --cov-report=term-missing",
        "test:e2e": "npx playwright test",
        "test:lint-readme": "! grep -rE 'default_model_id|model_list|ModelWeight' README.md packages/*/README.md && echo 'All README schema names are current.'",
        "py:sync": "cd packages/py-client && uv sync",
        "py:build": "nx run py-client:build",
        "py:publish": "cd packages/py-client && uv run twine upload dist/*",
        "ts:publish": "cd packages/ts-client && pnpm publish --access public",
        "build:docs": "nx build docs",
        "docs:dev": "nx dev docs",
        "affected:test": "nx affected -t test",
        "affected:build": "nx affected -t build",
        "graph": "nx graph"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "sharp",
            "workerd"
        ],
        "overrides": {
            "vite": ">=7.3.5",
            "esbuild": ">=0.28.1"
        }
    },
    "packageManager": "pnpm@10.22.0+sha512.bf049efe995b28f527fd2b41ae0474ce29186f7edcb3bf545087bd61fbbebb2bf75362d1307fda09c2d288e1e499787ac12d4fcb617a974718a6051f2eee741c",
    "devDependencies": {
        "@playwright/test": "^1.61.1",
        "@vitest/coverage-v8": "^4.1.9",
        "nx": "^23.0.1",
        "tsx": "^4.21.0"
    }
}
